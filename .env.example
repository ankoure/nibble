# Non-sensitive URLs and configuration are in chart/values.yaml.
# Copy this file to .env and fill in the values below.

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 ─────────────────────────────────────────────────────────────────────
# Default bucket used by agencies without an explicit s3Bucket override
NIBBLE_S3_BUCKET=
NIBBLE_S3_REGION=us-east-1

# ── Agency API keys ────────────────────────────────────────────────────────

# BAT (Brockton Area Transit Authority) - Passio RT URL contains credentials
BAT_GTFS_RT_URL=

# PVTA (Pioneer Valley Transit Authority) - Authorization header
PVTA_GTFS_RT_API_KEY=

# 511 SF Bay (shared by ACE, Caltrain, Capitol Corridor, SMART)
# https://511.org/open-data/token
ACE_AUTH_SECRET=
CALTRAIN_AUTH_SECRET=
CAPITOL_CORRIDOR_AUTH_SECRET=
SMART_AUTH_SECRET=

# Swiftly (shared by DCTA, NCTD)
# https://goswift.ly/realtime-api-key
DCTA_AUTH_SECRET=
NCTD_AUTH_SECRET=

# Metra
# https://metra.com/metra-gtfs-api
METRA_AUTH_SECRET=

# Metrolink
# https://metrolinktrains.com/about/gtfs/gtfs-rt-access/
METROLINK_AUTH_SECRET=

# Puget Sound OBA (shared by Sounder, King County Metro, Seattle Streetcar,
# Pierce Transit, Community Transit, Intercity Transit, WSF, Amtrak WA,
# Sound Transit, Seattle Monorail, Everett Transit, Kitsap Transit)
# email oba_api_key@soundtransit.org
OBA_PUGET_SOUND_API_KEY=
SOUNDER_AUTH_SECRET=

# TriMet (Oregon)
# https://developer.trimet.org/appid/registration/
TRIMET_AUTH_SECRET=
